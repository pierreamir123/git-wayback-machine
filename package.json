{
  "name": "git-wayback-machine",
  "displayName": "Git Wayback Machine",
  "description": "Visualize and replay your git history like a time machine.",
  "version": "2.0.0",
  "publisher": "PierreBassily",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/pierrebassily/git-wayback-machine"
  },
  "bugs": {
    "url": "https://github.com/pierrebassily/git-wayback-machine/issues"
  },
  "homepage": "https://github.com/pierrebassily/git-wayback-machine#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-wayback",
          "title": "Git Wayback",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "views": {
      "git-wayback": [
        {
          "id": "git-wayback-history",
          "name": "File History",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "git-wayback.openTimeline",
        "title": "Git Wayback: Open Timeline",
        "category": "Git Wayback"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "webview:dev": "cd webview && npm run dev",
    "webview:build": "cd webview && npm run build",
    "build": "npm run webview:build && npm run package",
    "vsix": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "ts-loader": "^9.5.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.9"
  }
}
